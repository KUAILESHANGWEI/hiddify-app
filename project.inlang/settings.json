{
  "$schema": "https://inlang.com/schema/project-settings",
  "sourceLanguageTag": "en",
  "languageTags": [
    "en",
    "ar",
    "ckb-KUR",
    "es",
    "fa",
    "fr",
    "id",
    "pt-BR",
    "ru",
    "tr",
    "zh-CN",
    "zh-TW",
    "hi"
  ],
  "modules": [
    "./modules/plugin-i18next-4.js",
    "./modules/message-lint-rule-empty-pattern-1.js",
    "./modules/message-lint-rule-identical-pattern-1.js",
    "./modules/message-lint-rule-without-source-1.js",
    "./modules/message-lint-rule-missing-translation-1.js",
    "./modules/message-lint-rule-missing-translation-latest.js"
  ],
  "plugin.inlang.i18next": {
    "pathPattern": "./assets/translations/strings_{languageTag}.i18n.json",
    "variableReferencePattern": [
      "@:"
    ]
  }
}
